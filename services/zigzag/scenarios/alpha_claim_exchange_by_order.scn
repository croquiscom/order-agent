# 지정 주문번호 교환 요청 + 비용 결제
# 사용법: python3 execute_scenario.py alpha_claim_exchange_by_order.scn --var order_number=주문번호
# 목적: 특정 주문번호의 주문 상세 진입 후 교환 요청 → 비용 결제 완료까지 검증

# 1) 주문 상세 직접 진입
ENSURE_LOGIN_ALPHA https://alpha.zigzag.kr/checkout/orders/{{order_number}}
NAVIGATE https://alpha.zigzag.kr/checkout/orders/{{order_number}}
WAIT_FOR 1500

# 2) 교환하기 클릭 -> 교환 요청 페이지 진입
EVAL "(() => { const norm=(s)=> (s||'').replace(/\\s+/g,'').trim(); const btns=[...document.querySelectorAll('button,[role=button],a')]; const leaf=btns.find(el=>norm(el.textContent)==='교환하기' || norm(el.textContent)==='교환신청'); if(!leaf) throw new Error('no_exchange_action'); leaf.dispatchEvent(new MouseEvent('click',{bubbles:true,cancelable:true,view:window})); return `clicked:${norm(leaf.textContent)}`; })()"
WAIT_URL /request-exchange
WAIT_FOR 700

# 3) 교환 사유 선택 + 제출
SUBMIT_EXCHANGE_REQUEST "__ASK__"
CHECK_NOT_URL /request-exchange

# 4) 교환비용 결제 (포인트 전액)
EVAL "(() => { const url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_exchange_cost_sheet'; const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const full=[...document.querySelectorAll('button,[role=button],a,div,span')].find(el=>txt(el).includes('포인트전액사용')); if(full){ (full.closest('button,[role=button],a,div,span')||full).click(); return 'exchange_point_full_applied'; } throw new Error('exchange_point_full_not_found'); })()"
WAIT_FOR 500
EVAL "(() => { const url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_exchange_cost_sheet'; const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const btn=[...document.querySelectorAll('button,[role=button],div,a,span')].find(el=>txt(el).includes('0원결제하기')||txt(el).includes('0원구매하기')); if(!btn) throw new Error('no_zero_exchange_pay_button'); (btn.closest('button,[role=button],div,a,span')||btn).click(); return `clicked:${txt(btn)}`; })()"
WAIT_URL /claim-order-completed

# 5) 완료 페이지에서 주문상세 이동 + 결과 확인
EVAL "(() => { const norm=(s)=>(s||'').replace(/\\s+/g,'').trim(); const all=[...document.querySelectorAll('a,button,[role=button],div,span')]; const target=all.find(el=>norm(el.textContent).includes('주문상세')||norm(el.textContent).includes('주문배송')||norm(el.textContent).includes('주문내역')); if(!target) throw new Error('no_order_detail_button_on_claim_complete'); (target.closest('a,button,[role=button],div,span')||target).click(); return `clicked:${norm(target.textContent)}`; })()"
WAIT_URL /checkout/orders/
EVAL "(() => { const t=((document.body&&document.body.innerText)||'').replace(/\\s+/g,''); if (!(t.includes('교환요청') || t.includes('교환중') || t.includes('교환완료'))) throw new Error('exchange_result_status_not_found'); return 'exchange_result_status_ok'; })()"
DUMP_STATE claim_exchange_by_order
