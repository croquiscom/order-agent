# 클레임 3종(취소/반품/교환) 진입 가능 여부 확인
# 목적: 주문내역에서 주문상세 진입 후 클레임 3종(취소/반품/교환) 진입 가능 여부 및 증적 수집

ENSURE_LOGIN_ALPHA https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 2500
CHECK_URL /checkout/orders

# 1) 취소
EVAL "(() => { const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const btn = [...document.querySelectorAll('button,[role=button],a,[role=link]')].find(b => txt(b).includes('주문상세')); if (!btn) throw new Error('no_order_detail_button'); btn.click(); return `clicked:${txt(btn)}`; })()"
WAIT_URL /checkout/orders
WAIT_FOR 1200
EVAL "(() => { const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const el=[...document.querySelectorAll('button,[role=button],a,[role=link]')].find(x=>txt(x).includes('취소')); if(!el) return 'no_cancel_action'; el.click(); return `clicked:${txt(el)}`; })()"
WAIT_FOR 1000
PRINT_ACTIVE_MODAL
DUMP_STATE claim_cancel

# 2) 반품
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 2000
EVAL "(() => { const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const btn = [...document.querySelectorAll('button,[role=button],a,[role=link]')].find(b => txt(b).includes('주문상세')); if (!btn) throw new Error('no_order_detail_button'); btn.click(); return `clicked:${txt(btn)}`; })()"
WAIT_URL /checkout/orders
WAIT_FOR 1200
EVAL "(() => { const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const el=[...document.querySelectorAll('button,[role=button],a,[role=link]')].find(x=>txt(x).includes('반품')); if(!el) return 'no_return_action'; el.click(); return `clicked:${txt(el)}`; })()"
WAIT_FOR 1000
PRINT_ACTIVE_MODAL
DUMP_STATE claim_return

# 3) 교환
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 2000
EVAL "(() => { const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const btn = [...document.querySelectorAll('button,[role=button],a,[role=link]')].find(b => txt(b).includes('주문상세')); if (!btn) throw new Error('no_order_detail_button'); btn.click(); return `clicked:${txt(btn)}`; })()"
WAIT_URL /checkout/orders
WAIT_FOR 1200
EVAL "(() => { const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const el=[...document.querySelectorAll('button,[role=button],a,[role=link]')].find(x=>txt(x).includes('교환')); if(!el) return 'no_exchange_action'; el.click(); return `clicked:${txt(el)}`; })()"
WAIT_FOR 1000
PRINT_ACTIVE_MODAL
DUMP_STATE claim_exchange
