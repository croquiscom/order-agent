# 교환 클레임 요청 + 비용 결제 완료
# 목적: 유저가 지정한 주문(ORDER_NO)에 대해 교환 요청 → 교환비용 결제 → 완료까지 검증
# 사용법: python3 services/zigzag/scripts/execute_scenario.py --var ORDER_NO=<주문번호> alpha_claim_exchange.scn

# 1) 로그인 확인 + 지정 주문상세 직접 진입
ENSURE_LOGIN_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders/{{ORDER_NO}}
WAIT_FOR 1500

# 2) 교환하기 버튼 확인 및 클릭 → 교환 요청 페이지 진입 (불가 시 사유 리포트 후 종결)
EVAL "(() => { const norm=(s)=> (s||'').replace(/\\s+/g,'').trim(); const btns=[...document.querySelectorAll('button,[role=button],a,div.btn')]; const leaf=btns.find(el=>{ const t=norm(el.textContent); return t==='교환하기' || t==='교환신청'; }); if(!leaf){ const body=norm(document.body.innerText||''); const reasons=[]; if(body.includes('구매확정')) reasons.push('구매확정 상태'); if(body.includes('교환불가')) reasons.push('교환불가 상품'); if(body.includes('취소완료')) reasons.push('취소완료 상태'); if(body.includes('반품')) reasons.push('반품 진행중'); if(body.includes('교환요청')||body.includes('교환중')||body.includes('교환완료')) reasons.push('이미 교환 처리됨'); if(!reasons.length) reasons.push('교환하기 버튼 없음(사유 불명)'); return 'CLAIM_NOT_AVAILABLE:' + reasons.join(','); } leaf.dispatchEvent(new MouseEvent('click',{bubbles:true,cancelable:true,view:window})); return 'clicked:'+norm(leaf.textContent); })()"
WAIT_URL /request-exchange
WAIT_FOR 700

# 3) 교환 사유 선택 + 제출
SUBMIT_EXCHANGE_REQUEST "__ASK__"
CHECK_NOT_URL /request-exchange

# 4) 교환비용 결제 (포인트 전액 → 0원 결제만 허용, 포인트 부족 시 리포트 종결)
EVAL "(() => { const url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_exchange_cost_sheet'; const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const full=[...document.querySelectorAll('button,[role=button],a,div,span')].find(el=>txt(el).includes('전액사용')); if(full){ (full.closest('button,[role=button],a,div,span')||full).click(); } return full ? 'point_full_clicked' : 'no_point_full_button'; })()"
WAIT_FOR 800
EVAL "(() => { const url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_exchange_cost_sheet'; const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const has0=[...document.querySelectorAll('button,[role=button],div,a,span')].some(el=>{const t=txt(el);return t==='0원결제하기'||t==='0원구매하기'||t==='0원 결제하기'||t==='0원 구매하기';}); if(has0) return 'zero_pay_available'; const pays=[...document.querySelectorAll('button,[role=button],div,a,span')].filter(el=>/\\d.*원.*결제/.test(txt(el))); const payLeaf=pays.length?pays.reduce((a,b)=>txt(a).length<=txt(b).length?a:b):null; const cost=payLeaf?txt(payLeaf):'알수없음'; return 'CLAIM_NOT_AVAILABLE:포인트 부족 — 교환비용 결제 필요('+cost+'), 실제 결제는 안전정책상 차단됨'; })()"
CLICK "text=0원 결제하기"
WAIT_URL /claim-order-completed

# 5) 완료 페이지에서 주문상세 이동 + 결과 확인
CLICK "text=주문상세 보기"
WAIT_URL /checkout/orders/
EVAL "(() => { const t=((document.body&&document.body.innerText)||'').replace(/\\s+/g,''); if (!(t.includes('교환요청') || t.includes('교환중') || t.includes('교환완료'))) throw new Error('exchange_result_status_not_found'); return 'exchange_result_status_ok'; })()"
DUMP_STATE claim_exchange
