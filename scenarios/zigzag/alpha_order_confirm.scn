# @title: 구매확정 플로우
# @tier: regression
# @area: order
# @pages: /checkout/orders, /confirm, /confirm-completed

# 1) 주문 목록 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 1500

# 2) 배송완료 상태 주문 진입
APPLY_ORDER_STATUS_FILTER 배송완료
WAIT_FOR 1500
CLICK_ORDER_DETAIL_BY_STATUS 배송완료
WAIT_URL /checkout/orders/
WAIT_FOR 1200

# 3) 구매확정 버튼 탐색 + 클릭
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button],a,div.btn')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t === '구매확정' || t === '구매확정하기') { btn = btns[i]; break; } } if (!btn) { var body = norm(document.body.innerText || ''); var reasons = []; if (body.indexOf('교환') >= 0 || body.indexOf('반품') >= 0) reasons.push('클레임진행중'); if (body.indexOf('구매확정완료') >= 0) reasons.push('이미확정됨'); if (!reasons.length) reasons.push('구매확정 버튼 없음'); return 'REPORT:구매확정_불가:' + reasons.join(','); } btn.dispatchEvent(new MouseEvent('click', {bubbles: true, cancelable: true, view: window})); return 'clicked:구매확정'; })()"
WAIT_FOR 1500

# 4) 확인 모달/다이얼로그 처리
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button]')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t === '확인' || t === '구매확정하기' || t === '네') { btn = btns[i]; break; } } if (btn) { btn.click(); return 'confirm_clicked'; } return 'no_confirm_modal'; })()"
WAIT_FOR 2000

# 5) 구매확정 완료 확인
EVAL "(function() { var url = location.href; var body = (document.body.innerText || '').replace(/\\s+/g, ''); if (url.indexOf('/confirm-completed') >= 0) return 'confirm_completed_page'; if (body.indexOf('구매확정완료') >= 0 || body.indexOf('구매확정이완료') >= 0) return 'confirm_completed_text'; return 'REPORT:구매확정_결과_미확인:url=' + url; })()"
DUMP_STATE order_confirm
