# @title: 교환 요청 상세 정보 조회
# @tier: regression
# @area: claim, exchange
# @pages: /checkout/orders, /order-item-requests, /exchange-info

# 1) 주문 목록 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 1500

# 2) 교환 상태 주문 탐색
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var elems = [].slice.call(document.querySelectorAll('*')); var found = null; for (var i = 0; i < elems.length; i++) { var t = norm(elems[i].textContent); if ((t === '교환요청' || t === '교환중' || t === '교환완료') && elems[i].offsetHeight > 0 && t.length < 10) { found = elems[i]; break; } } if (!found) return 'REPORT:교환상태_주문_없음'; var link = found.closest('a'); if (!link) { var p = found.parentElement; while (p && p !== document.body) { if (p.tagName === 'A') { link = p; break; } p = p.parentElement; } } if (link) { link.click(); return 'clicked_exchange_order'; } return 'REPORT:교환주문_클릭불가'; })()"
WAIT_URL /checkout/orders/
WAIT_FOR 1200

# 3) 교환 정보 보기 버튼 클릭
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button],a')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t.indexOf('교환정보') >= 0 || t === '교환상세' || t === '교환내역') { btn = btns[i]; break; } } if (!btn) return 'REPORT:교환정보_버튼_없음'; btn.click(); return 'clicked:교환정보'; })()"
WAIT_FOR 1500

# 4) 교환 정보 페이지 확인
EVAL "(function() { var url = location.href; var body = (document.body.innerText || '').replace(/\\s+/g, ''); if (url.indexOf('/exchange-info') >= 0) return 'exchange_info_page_ok'; if (body.indexOf('교환사유') >= 0 || body.indexOf('교환옵션') >= 0) return 'exchange_info_content_ok'; return 'REPORT:교환정보_페이지_미도달:url=' + url; })()"
DUMP_STATE claim_exchange_info
