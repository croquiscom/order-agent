# 교환비용 결제 (포인트 전액 -> 0원 결제만 허용, 포인트 부족 시 리포트 종결)
EVAL "(() => { const url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_exchange_cost_sheet'; const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const full=[...document.querySelectorAll('button,[role=button],a,div,span')].find(el=>txt(el).includes('전액사용')); if(full){ (full.closest('button,[role=button],a,div,span')||full).click(); } return full ? 'point_full_clicked' : 'no_point_full_button'; })()"
WAIT_FOR 800
EVAL "(() => { const url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_exchange_cost_sheet'; const txt=(el)=>(el.textContent||'').replace(/\\s+/g,'').trim(); const has0=[...document.querySelectorAll('button,[role=button],div,a,span')].some(el=>{const t=txt(el);return t==='0원결제하기'||t==='0원구매하기'||t==='0원 결제하기'||t==='0원 구매하기';}); if(has0) return 'zero_pay_available'; const pays=[...document.querySelectorAll('button,[role=button],div,a,span')].filter(el=>/\\d.*원.*결제/.test(txt(el))); const payLeaf=pays.length?pays.reduce((a,b)=>txt(a).length<=txt(b).length?a:b):null; const cost=payLeaf?txt(payLeaf):'알수없음'; return 'CLAIM_NOT_AVAILABLE:포인트 부족 — 교환비용 결제 필요('+cost+'), 실제 결제는 안전정책상 차단됨'; })()"
EVAL "(() => { var url=location.href; if(!url.includes('/order-sheets/exchange')) return 'skip_no_exchange_cost_sheet'; var t=function(el){return(el.textContent||'').trim();}; var match=function(s){return s==='0원결제하기'||s==='0원구매하기'||s==='0원 결제하기'||s==='0원 구매하기';}; var btn=[...document.querySelectorAll('button')].find(function(el){return match(t(el));}); if(!btn) btn=[...document.querySelectorAll('[role=button],div,a,span')].find(function(el){return match(t(el));}); if(btn){btn.click();return 'zero_pay_clicked:'+btn.tagName;} throw new Error('zero_pay_button_not_found'); })()"
WAIT_FOR 3000
