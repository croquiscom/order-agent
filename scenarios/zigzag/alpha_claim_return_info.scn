# @title: 반품 요청 상세 정보 조회
# @tier: regression
# @area: claim, return
# @pages: /checkout/orders, /order-item-requests, /return-info

# 1) 주문 목록 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 1500

# 2) 반품 상태 주문 탐색
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var elems = [].slice.call(document.querySelectorAll('*')); var found = null; for (var i = 0; i < elems.length; i++) { var t = norm(elems[i].textContent); if ((t === '반품요청' || t === '반품중' || t === '반품완료' || t === '수거중') && elems[i].offsetHeight > 0 && t.length < 10) { found = elems[i]; break; } } if (!found) return 'REPORT:반품상태_주문_없음'; var link = found.closest('a'); if (!link) { var p = found.parentElement; while (p && p !== document.body) { if (p.tagName === 'A') { link = p; break; } p = p.parentElement; } } if (link) { link.click(); return 'clicked_return_order'; } return 'REPORT:반품주문_클릭불가'; })()"
WAIT_URL /checkout/orders/
WAIT_FOR 1200

# 3) 반품 정보 보기 버튼 클릭
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button],a')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t.indexOf('반품정보') >= 0 || t === '반품상세' || t === '반품내역') { btn = btns[i]; break; } } if (!btn) return 'REPORT:반품정보_버튼_없음'; btn.click(); return 'clicked:반품정보'; })()"
WAIT_FOR 1500

# 4) 반품 정보 페이지 확인
EVAL "(function() { var url = location.href; var body = (document.body.innerText || '').replace(/\\s+/g, ''); if (url.indexOf('/return-info') >= 0) return 'return_info_page_ok'; if (body.indexOf('반품사유') >= 0 || body.indexOf('수거정보') >= 0 || body.indexOf('환불정보') >= 0) return 'return_info_content_ok'; return 'REPORT:반품정보_페이지_미도달:url=' + url; })()"
DUMP_STATE claim_return_info
