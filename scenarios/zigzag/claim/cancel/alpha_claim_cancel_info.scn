# @title: 취소 요청 상세 정보 조회
# @tier: regression
# @area: claim, cancel
# @pages: /checkout/orders, /order-item-requests, /cancel-info
# @priority: P2
# @lifecycle: regression
# @preconditions: order_status=결제완료, claim_type=취소

# 1) 주문 목록 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 1500

# 2) 취소 완료/처리 중인 주문 탐색
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var elems = [].slice.call(document.querySelectorAll('*')); var found = null; for (var i = 0; i < elems.length; i++) { var t = norm(elems[i].textContent); if ((t === '취소완료' || t === '취소요청' || t === '취소중') && elems[i].offsetHeight > 0 && t.length < 10) { found = elems[i]; break; } } if (!found) return 'REPORT:취소상태_주문_없음'; var link = found.closest('a'); if (!link) { var p = found.parentElement; while (p && p !== document.body) { if (p.tagName === 'A') { link = p; break; } p = p.parentElement; } } if (link) { link.click(); return 'clicked_cancel_order'; } return 'REPORT:취소주문_클릭불가'; })()"
WAIT_URL /checkout/orders/
WAIT_FOR 1200

# 3) 취소 정보 보기 버튼 클릭
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button],a')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t.indexOf('취소정보') >= 0 || t === '취소상세' || t === '취소내역') { btn = btns[i]; break; } } if (!btn) return 'REPORT:취소정보_버튼_없음:주문상세에서 취소 정보 버튼을 찾지 못했습니다'; btn.click(); return 'clicked:취소정보'; })()"
WAIT_FOR 1500

# 4) 취소 정보 페이지 확인
EVAL "(function() { var url = location.href; var body = (document.body.innerText || '').replace(/\\s+/g, ''); if (url.indexOf('/cancel-info') >= 0) return 'cancel_info_page_ok'; if (body.indexOf('취소사유') >= 0 || body.indexOf('환불정보') >= 0 || body.indexOf('환불금액') >= 0) return 'cancel_info_content_ok'; return 'REPORT:취소정보_페이지_미도달:url=' + url; })()"
DUMP_STATE claim_cancel_info
