# @title: 1+1 묶음 정책 교환 차단 검증
# @tier: regression
# @area: claim, exchange, policy
# @pages: /checkout/orders, /claim
# @usage: python3 executor/execute_scenario.py --var ORDER_NO=<1+1상품_주문번호> scenarios/zigzag/alpha_claim_exchange_policy_1p1.scn
# @note: 1+1 묶음 정책 상품에 대한 교환 시도 → EXCHANGE_POLICY_BLOCKED 차단 확인 → PASS로 정상 종결
# @priority: P1
# @lifecycle: regression
# @preconditions: order_status=배송완료, claim_type=교환, product_type=1+1묶음

# 1) 주문풀에서 배송완료 주문 할당 (--var ORDER_NO=xxx 로 직접 지정 가능)
PICK_ORDER_FROM_POOL 배송완료 ORDER_NO

# 2) 로그인 확인 + 지정 주문상세 직접 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders/{{ORDER_NO}}
WAIT_FOR 1500

# 2) 현재 페이지 상태 덤프 (교환하기 버튼 존재 여부 확인용)
DUMP_STATE before_1p1_exchange_attempt

# 3) 교환하기 클릭 → 교환 요청 페이지 진입
EVAL "(() => { const norm=(s)=> (s||'').replace(/\\s+/g,'').trim(); const btns=[...document.querySelectorAll('button,[role=button],a,div.btn')]; const leaf=btns.find(el=>{ const t=norm(el.textContent); return t==='교환하기' || t==='교환신청'; }); if(!leaf){ const body=norm(document.body.innerText||''); const reasons=[]; if(body.includes('1+1')||body.includes('1 +1')||body.includes('교환불가')) reasons.push('1+1 정책 교환불가'); if(body.includes('구매확정')) reasons.push('구매확정 상태'); if(!reasons.length) reasons.push('교환하기 버튼 없음(1+1 정책 차단 추정)'); return 'CLAIM_NOT_AVAILABLE:' + reasons.join(','); } leaf.dispatchEvent(new MouseEvent('click',{bubbles:true,cancelable:true,view:window})); return 'clicked:'+norm(leaf.textContent); })()"
WAIT_URL /request-exchange
WAIT_FOR 700

# 4) 교환 사유 선택 + 제출 → 1+1 정책 차단 기대
EXPECT_FAIL EXCHANGE_POLICY_BLOCKED
SUBMIT_EXCHANGE_REQUEST "__ASK__"

DUMP_STATE claim_exchange_policy_1p1_blocked
