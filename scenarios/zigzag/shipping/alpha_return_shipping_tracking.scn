# @title: 반품 수거 추적 페이지 확인
# @tier: regression
# @area: claim, return, shipping
# @pages: /checkout/orders, /return-shipping-tracking
# @priority: P1
# @lifecycle: regression

# 1) 주문 목록 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders
WAIT_FOR 1500

# 2) 반품/수거 상태 주문 탐색
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var elems = [].slice.call(document.querySelectorAll('*')); var found = null; for (var i = 0; i < elems.length; i++) { var t = norm(elems[i].textContent); if ((t === '수거중' || t === '반품중' || t === '반품요청') && elems[i].offsetHeight > 0 && t.length < 10) { found = elems[i]; break; } } if (!found) return 'REPORT:반품수거_주문_없음:수거중/반품중 상태 주문이 목록에 없습니다'; var link = found.closest('a'); if (!link) { var p = found.parentElement; while (p && p !== document.body) { if (p.tagName === 'A') { link = p; break; } p = p.parentElement; } } if (link) { link.click(); return 'clicked_return_order'; } return 'REPORT:반품주문_클릭불가'; })()"
WAIT_FOR 1500

# 3) 수거 추적 / 반품 배송 조회 버튼 클릭
EVAL "(function() { if (location.href.indexOf('/checkout/orders/') < 0) return 'REPORT:주문상세_미도달'; var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button],a')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t === '수거조회' || t === '수거추적' || t.indexOf('반품배송') >= 0 || t.indexOf('수거현황') >= 0) { btn = btns[i]; break; } } if (!btn) return 'REPORT:수거조회_버튼_없음'; btn.click(); return 'clicked:수거조회'; })()"
WAIT_FOR 2000

# 4) 반품 수거 추적 페이지 확인
EVAL "(function() { var url = location.href; var body = (document.body.innerText || '').replace(/\\s+/g, ''); if (url.indexOf('/return-shipping-tracking') >= 0) return 'return_shipping_tracking_page_ok'; if (body.indexOf('수거현황') >= 0 || body.indexOf('수거중') >= 0 || body.indexOf('운송장') >= 0) return 'return_tracking_content_ok'; return 'REPORT:반품수거추적_페이지_미도달:url=' + url; })()"
DUMP_STATE return_shipping_tracking
