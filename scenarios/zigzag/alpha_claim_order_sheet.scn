# @title: 클레임 주문서 진입 확인 (교환 비용 결제)
# @tier: regression
# @area: claim, exchange, payment
# @pages: /checkout/orders, /order-sheets
# @usage: python3 executor/execute_scenario.py --var ORDER_NO=<주문번호> scenarios/zigzag/alpha_claim_order_sheet.scn

# 1) 로그인 + 지정 주문상세 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders
NAVIGATE https://alpha.zigzag.kr/checkout/orders/{{ORDER_NO}}
WAIT_FOR 1500

# 2) 교환하기 클릭
EVAL "(function() { var norm = function(s) { return (s || '').replace(/\\s+/g, '').trim(); }; var btns = [].slice.call(document.querySelectorAll('button,[role=button],a,div.btn')); var btn = null; for (var i = 0; i < btns.length; i++) { var t = norm(btns[i].textContent); if (t === '교환하기' || t === '교환신청') { btn = btns[i]; break; } } if (!btn) return 'REPORT:교환하기_버튼_없음'; btn.dispatchEvent(new MouseEvent('click', {bubbles: true, cancelable: true, view: window})); return 'clicked:교환하기'; })()"
WAIT_URL /request-exchange
WAIT_FOR 700

# 3) 교환 사유 + 제출
SUBMIT_EXCHANGE_REQUEST "__ASK__"
WAIT_FOR 1500

# 4) 클레임 주문서 페이지 확인 (교환비용 결제 시트)
EVAL "(function() { var url = location.href; if (url.indexOf('/order-sheets/') >= 0) { var body = (document.body.innerText || '').replace(/\\s+/g, ''); var hasPayment = body.indexOf('결제') >= 0 || body.indexOf('포인트') >= 0; return 'claim_order_sheet_page:payment=' + hasPayment; } if (url.indexOf('/checkout/orders/') >= 0) return 'REPORT:클레임주문서_스킵:추가비용없는교환(주문상세로직접이동)'; return 'REPORT:예상외_페이지:url=' + url; })()"
DUMP_STATE claim_order_sheet
