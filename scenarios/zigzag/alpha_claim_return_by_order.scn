# 지정 주문번호 반품 요청 + 비용 결제
# 사용법: python3 execute_scenario.py alpha_claim_return_by_order.scn --var order_number=주문번호
# 목적: 특정 주문번호의 주문 상세 진입 후 반품 요청 → 비용 결제 완료까지 검증

# 1) 주문 상세 직접 진입
ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/checkout/orders/{{order_number}}
NAVIGATE https://alpha.zigzag.kr/checkout/orders/{{order_number}}
WAIT_FOR 1500

# 2) 반품하기 클릭 -> 반품 요청 페이지 진입
EVAL "(() => { const norm=(s)=> (s||'').replace(/\\s+/g,'').trim(); const all=[...document.querySelectorAll('*')]; const leaf=all.find(el=>norm(el.textContent)==='반품하기' || norm(el.textContent)==='반품신청' || norm(el.textContent)==='반품'); if(!leaf) throw new Error('no_return_action'); const clickable=leaf.closest('button,[role=button],a,[role=link],[tabindex],div,span') || leaf; clickable.dispatchEvent(new MouseEvent('click',{bubbles:true,cancelable:true,view:window})); return `clicked:${norm(clickable.textContent)}`; })()"
WAIT_URL /request-return
WAIT_FOR 700

# 3) 반품 사유 선택 + 제출
SUBMIT_RETURN_REQUEST "__ASK__"
CHECK_NOT_URL /request-return

# 4) 반품비용 결제 (포인트 전액)
CHECK_URL /order-sheets/return
CLICK text=전액사용
WAIT_FOR 500
CLICK "text=0원 결제하기"
WAIT_URL /claim-order-completed

# 5) 완료 페이지에서 주문상세 이동 + 결과 확인
CLICK "text=주문 상세보기"
WAIT_URL /checkout/orders/

# 6) 반품 결과 확인
EVAL "(() => { const t=((document.body&&document.body.innerText)||'').replace(/\\s+/g,''); if (!(t.includes('반품요청') || t.includes('반품중') || t.includes('반품완료'))) throw new Error('return_result_status_not_found'); return 'return_result_status_ok'; })()"
DUMP_STATE claim_return_by_order
