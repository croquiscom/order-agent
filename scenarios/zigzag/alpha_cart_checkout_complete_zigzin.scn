# 장바구니 담기 → 구매 완료 — 직진배송
# 목표: 상품페이지 -> 장바구니 담기 -> 장바구니 구매 -> 포인트 전액 -> 주문완료 확인

ENSURE_LOGIN_ALPHA https://alpha.zigzag.kr/catalog/products/100100014
WAIT_FOR 1200

NAVIGATE https://alpha.zigzag.kr/catalog/products/100100014
WAIT_FOR 2000

# PDP 하단 구매 레이어에서 장바구니 담기
EVAL "(async () => { const text = (el) => (el && el.textContent ? el.textContent : '').replace(/\\s+/g,'').trim(); const btn = (name) => [...document.querySelectorAll('button,[role=button]')].find(b => text(b) === name); const buy = btn('구매하기'); if (!buy) throw new Error('no_buy_button'); buy.click(); await new Promise(r => setTimeout(r, 500)); const cart = btn('장바구니'); if (!cart) throw new Error('no_cart_button'); cart.click(); return 'clicked_cart'; })()"
WAIT_FOR 1500

# 장바구니에서 구매
NAVIGATE https://alpha.zigzag.kr/checkout/cart?from=pdp
WAIT_FOR 1800
PRESS Escape
CLICK_SNAPSHOT_TEXT "구매하기"
WAIT_URL /checkout/order-sheets/
CHECK_URL /checkout/order-sheets/
CHECK_NEW_ORDER_SHEET

# 주문서: 포인트 전액 결제
WAIT_FOR "text=전액사용"
CHECK "text=전액사용"
CLICK_SNAPSHOT_TEXT "포인트 전액사용"
WAIT_FOR 1200
CHECK "text=0원"
EVAL "(() => { const cbs = [...document.querySelectorAll('input[type=checkbox]')]; let cb = cbs.find(el => (((el.closest('label,section,div,article') || document.body).textContent) || '').includes('주문내용 확인 및 결제 동의')); if (!cb) cb = cbs[cbs.length - 1] || null; if (!cb) return 'no_checkbox'; if (!cb.checked) cb.click(); cb.dispatchEvent(new Event('input', { bubbles: true })); cb.dispatchEvent(new Event('change', { bubbles: true })); return cb.checked ? 'checked' : 'not_checked'; })()"
WAIT_FOR 400
EVAL "(() => { const txt = (el) => (el.textContent || '').replace(/\\s+/g,'').trim(); const btn = [...document.querySelectorAll('button,[role=button]')].find(el => txt(el).includes('0원구매하기') || txt(el).includes('0원결제하기')); if (!btn) return 'no_zero_pay_button'; btn.click(); return `clicked:${txt(btn)}`; })()"
WAIT_FOR 1200
PRINT_ACTIVE_MODAL
WAIT_FOR 2000
PRINT_ACTIVE_MODAL
DUMP_STATE cart_checkout_after_pay_click_zigzin

# 주문완료 확인
CHECK_PAYMENT_RESULT
DUMP_STATE cart_checkout_complete_zigzin
