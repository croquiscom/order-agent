# 결제 차단 모달 캡처
# 목적: 결제 시도 후 활성 모달/차단 메시지 캡처

ENSURE_LOGIN_ZIGZAG_ALPHA https://alpha.zigzag.kr/catalog/products/100136725
WAIT_FOR 1200

NAVIGATE https://alpha.zigzag.kr/catalog/products/100136725
WAIT_FOR 2000
EVAL "(async () => { const text = (el) => (el && el.textContent ? el.textContent : '').replace(/\\s+/g,'').trim(); const btn = (name) => [...document.querySelectorAll('button,[role=button]')].find(b => text(b) === name); const buy = btn('구매하기'); if (!buy) throw new Error('no_buy_button'); buy.click(); await new Promise(r => setTimeout(r, 500)); const direct = btn('바로구매'); if (!direct) throw new Error('no_direct_button'); direct.click(); return 'clicked_direct'; })()"
WAIT_URL /checkout/order-sheets/
CHECK_URL /checkout/order-sheets/
CHECK_NEW_ORDER_SHEET

WAIT_FOR "text=전액사용"
CLICK_SNAPSHOT_TEXT "포인트 전액사용"
WAIT_FOR 1200
EVAL "(() => { const cbs = [...document.querySelectorAll('input[type=checkbox]')]; let cb = cbs.find(el => (((el.closest('label,section,div,article') || document.body).textContent) || '').includes('주문내용 확인 및 결제 동의')); if (!cb) cb = cbs[cbs.length - 1] || null; if (!cb) return 'no_checkbox'; if (!cb.checked) cb.click(); cb.dispatchEvent(new Event('input', { bubbles: true })); cb.dispatchEvent(new Event('change', { bubbles: true })); return cb.checked ? 'checked' : 'not_checked'; })()"
WAIT_FOR 300
EVAL "(() => { const txt = (el) => (el.textContent || '').replace(/\\s+/g,'').trim(); const btn = [...document.querySelectorAll('button,[role=button]')].find(el => txt(el).includes('결제하기') || txt(el).includes('구매하기')); if (!btn) throw new Error('no_pay_button'); btn.click(); return txt(btn); })()"
WAIT_FOR 1200
PRINT_ACTIVE_MODAL
DUMP_STATE payment_blocked_modal_after_pay_click
