# @title: Grafana 로그인 (Keycloak-OAuth + OTP)
# @tier: full
# @area: infra, login
# @usage: python3 executor/execute_scenario.py scenarios/grafana/login.scn

# GRAFANA_USERNAME / GRAFANA_PASSWORD 환경변수를 .env에 설정해야 합니다.
# OTP는 Authenticator 확장프로그램의 "deploy" 계정에서 자동 읽기합니다.

# 1) Grafana 로그인 보장 (Keycloak-OAuth + OTP 자동 처리)
ENSURE_LOGIN_GRAFANA https://grafana.zigzag.in/

# 2) Grafana 대시보드 진입 확인
CHECK_URL grafana.zigzag.in
CHECK_NOT_URL /login

# 3) 세션 정보 추출 (grafana_session, grafana_session_expiry 포함)
DUMP_STATE grafana_session
