# AWS SSO 로그인 시나리오
# 사용법: python3 executor/execute_scenario.py scenarios/aws/sso_login.scn \
#          --var username=ace.f1 --var password=YOUR_PASSWORD
#
# OTP는 Authenticator 확장프로그램에서 자동으로 읽습니다.

# 1) AWS SSO 포털 접속
NAVIGATE https://kakaostyle.awsapps.com/start

# 2) 계정(이메일) 입력
WAIT_FOR role=textbox
FILL role=textbox {{username}}
CLICK button[type=submit]

# 3) 비밀번호 입력
WAIT_FOR 3000
WAIT_FOR role=textbox
FILL role=textbox {{password}}
CLICK button[type=submit]

# 4) OTP 입력 - Authenticator 확장프로그램에서 자동 읽기
WAIT_FOR 3000
READ_OTP "AWS SSO" otp
WAIT_FOR role=textbox
FILL role=textbox {{otp}}
CLICK button[type=submit]

# 5) SSO 콘솔 로그인 완료 확인
WAIT_URL awsapps.com/start
