# @title: AWS SSO 로그인
# @tier: full
# @area: infra, login
# @priority: P2
# @lifecycle: active
# @usage: python3 executor/execute_scenario.py scenarios/aws/sso_login.scn

# AWS_SSO_USERNAME / AWS_SSO_PASSWORD 환경변수를 .env에 설정해야 합니다.
# OTP는 Authenticator 확장프로그램의 "AWS SSO" 계정에서 자동 읽기합니다.

# 1) AWS SSO 로그인 보장 (username → password → OTP 자동 처리)
ENSURE_LOGIN_AWS_SSO https://kakaostyle.awsapps.com/start

# 2) SSO 콘솔 로그인 완료 확인
WAIT_URL awsapps.com/start
